# ====================================================================
# .env.example — 환경변수 설정 예시
#
# 이 파일을 복사하여 .env 로 저장한 뒤 실제 값을 입력하세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 포함되어 있습니다).
# 배포 환경(Railway 등)에서는 플랫폼의 환경변수 설정 화면을 사용하세요.
# ====================================================================

# [필수] Airtable API 키
# Airtable 계정 > Developer Hub > Personal Access Tokens 에서 발급
AIRTABLE_API_KEY=your_airtable_api_key_here

# [필수] Airtable PDF 첨부 필드 ID
# Airtable 테이블에서 PDF를 업로드할 첨부 파일 필드의 ID
# 필드 ID 확인: Airtable API 문서 또는 필드 설정에서 확인
# division_config.js 의 airtablePdfFieldId 값과 일치시키세요.
AIRTABLE_PDF_FIELD_ID=fldXXXXXXXXXXXXXX

# [선택] 서버 포트 (기본값: 3001)
PORT=3001

# [선택] 사업부 식별명 (/health 엔드포인트 응답에 포함)
DIVISION_NAME=정보통신사업부
